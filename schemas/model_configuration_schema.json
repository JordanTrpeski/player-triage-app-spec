{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "model_configuration_schema.json",
  "title": "OptionalLocalModelConfiguration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "enabled",
    "approved_model_id",
    "revision",
    "sha256",
    "local_path_reference",
    "runtime",
    "runtime_version",
    "context_limit",
    "output_token_limit",
    "timeout_seconds",
    "generation",
    "prompt_version",
    "prompt_sha256",
    "allowed_languages",
    "approval_status"
  ],
  "properties": {
    "version": {"type": "string", "enum": ["1.0.0", "1.0.1"]},
    "enabled": {"type": "boolean"},
    "approved_model_id": {"type": "string", "minLength": 3},
    "revision": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "local_path_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["environment_variable", "default_scope", "filename"],
      "properties": {
        "environment_variable": {"type": "string", "const": "PLAYER_TRIAGE_MODEL_PATH"},
        "default_scope": {"type": "string", "const": "user_model_directory"},
        "filename": {"type": "string", "pattern": "^[A-Za-z0-9._-]+\\.gguf$"}
      }
    },
    "runtime": {"type": "string", "const": "llama-cpp-python"},
    "runtime_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "context_limit": {"type": "integer", "minimum": 512, "maximum": 8192},
    "output_token_limit": {"type": "integer", "minimum": 64, "maximum": 512},
    "timeout_seconds": {"type": "number", "exclusiveMinimum": 0, "maximum": 120},
    "generation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["temperature", "max_schema_retries", "constrained_json"],
      "properties": {
        "temperature": {"type": "number", "const": 0},
        "max_schema_retries": {"type": "integer", "minimum": 0, "maximum": 1},
        "constrained_json": {"type": "boolean", "const": true}
      }
    },
    "prompt_version": {"type": "string", "const": "classifier-prompt-1.0.0"},
    "prompt_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "allowed_languages": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[a-z]{2}(?:-[A-Z]{2})?$"}
    },
    "approval_status": {
      "type": "string",
      "enum": ["evaluation_only", "approved_optional", "deferred", "rejected"]
    }
  }
}

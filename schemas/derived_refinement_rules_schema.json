{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "derived_refinement_rules_schema.json",
  "title": "DerivedRefinementRules",
  "description": "Versioned, auditable derived-refinement policy component. Generic deterministic refinements applied after the baseline and post-semantic stages. No rule may reference a message id or a raw-body equality check.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "rules"
  ],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "when",
          "policy_basis_ids"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^DERIVED_[A-Z0-9_]+$"
          },
          "description": {
            "type": "string"
          },
          "when": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "intent_in": {
                "type": "array",
                "items": {"type": "string"}
              },
              "regex_any": {
                "type": "array",
                "items": {"type": "string"}
              },
              "regex_all": {
                "type": "array",
                "items": {"type": "string"}
              },
              "regex_none": {
                "type": "array",
                "items": {"type": "string"}
              },
              "flags_all": {
                "type": "array",
                "items": {"type": "string"}
              },
              "flags_any": {
                "type": "array",
                "items": {"type": "string"}
              },
              "flags_none": {
                "type": "array",
                "items": {"type": "string"}
              },
              "repeat_or_related": {
                "type": "boolean"
              },
              "min_previous_contact": {
                "type": "integer",
                "minimum": 0
              }
            }
          },
          "set": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "category": {"type": "string"},
              "intent": {"type": "string"},
              "priority": {"type": "string"},
              "route": {"type": "string"},
              "assigned_team": {"type": "string"},
              "auto_response_policy": {"type": "string"},
              "auto_response_template_id": {"type": ["string", "null"]},
              "human_review_required": {"type": "boolean"},
              "model_eligibility": {"type": "string"},
              "model_bypass_reason": {"type": ["string", "null"]}
            }
          },
          "minimum_priority": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "add": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "secondary_intents": {"type": "array", "items": {"type": "string"}},
              "secondary_teams": {"type": "array", "items": {"type": "string"}},
              "risk_flags": {"type": "array", "items": {"type": "string"}},
              "reason_codes": {"type": "array", "items": {"type": "string"}}
            }
          },
          "editability": {
            "type": "string",
            "enum": ["locked", "guarded", "editable"]
          },
          "policy_basis_ids": {
            "type": "array",
            "items": {"type": "string"},
            "minItems": 1
          }
        }
      }
    }
  }
}

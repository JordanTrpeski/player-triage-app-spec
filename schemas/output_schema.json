  "allOf": [
    {
      "if": {
        "properties": {
          "route": {
            "const": "auto_respond"
          }
        }
      },
      "then": {
        "properties": {
          "priority": {
            "const": "low"
          },
          "auto_response_policy": {
            "const": "allowed_template"
          },
          "human_review_required": {
            "const": false
          },
          "auto_response_template_id": {
            "type": "string"
          }
        },
        "required": [
          "auto_response_template_id"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "route": {
            "enum": [
              "human",
              "specialist"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "human_review_required": {
            "const": true
          },
          "auto_response_template_id": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "priority": {
            "const": "critical"
          }
        }
      },
      "then": {
        "properties": {
          "route": {
            "const": "specialist"
          },
          "human_review_required": {
            "const": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "model_eligibility": {
            "enum": [
              "bypass_deterministic",
              "bypass_sensitive",
              "bypass_attachment",
              "bypass_untrusted_input"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "model_called": {
            "const": false
          },
          "model_bypass_reason": {
            "type": "string"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "model_eligibility": {
            "enum": [
              "eligible",
              "eligible_text_only"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "model_bypass_reason": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "attachment_received": {
            "const": true
          }
        }
      },
      "then": {
        "properties": {
          "model_eligibility": {
            "enum": [
              "eligible_text_only",
              "bypass_attachment"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "model_eligibility": {
            "const": "bypass_untrusted_input"
          }
        }
      },
      "then": {
        "properties": {
          "risk_flags": {
            "contains": {
              "const": "prompt_injection_detected"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "market_framework_status": {
            "const": "prohibited_market"
          }
        }
      },
      "then": {
        "properties": {
          "route": {
            "enum": [
              "human",
              "specialist"
            ]
          },
          "human_review_required": {
            "const": true
          },
          "secondary_teams": {
            "contains": {
              "const": "Market Compliance"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "processing_status": {
            "const": "provisional_fallback"
          }
        }
      },
      "then": {
        "properties": {
          "route": {
            "enum": [
              "human",
              "specialist"
            ]
          },
          "human_review_required": {
            "const": true
          },
          "auto_response_policy": {
            "enum": [
              "prohibited",
              "acknowledgment_only",
              "requires_approval"
            ]
          }
        }
      }
    }
  ]
}

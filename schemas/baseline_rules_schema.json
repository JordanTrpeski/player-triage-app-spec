{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "baseline_rules_schema.json",
  "title": "BaselineIntentRules",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "rules",
    "post_classification_refinements",
    "behaviour_fixtures"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "enabled",
          "category",
          "intent",
          "score",
          "match_mode",
          "patterns"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean"
          },
          "category": {
            "type": "string",
            "enum": [
              "Payments & Withdrawals",
              "KYC & Verification",
              "Bonuses & Promotions",
              "Technical & Game Issues",
              "Responsible Gambling",
              "Fraud & Compliance",
              "Complaints & Regulatory",
              "General"
            ]
          },
          "intent": {
            "type": "string",
            "enum": [
              "account_closure",
              "account_reopen_review",
              "account_transaction_statement_request",
              "account_takeover_report",
              "advertised_bonus_eligibility_dispute",
              "bonus_completed",
              "bonus_max_bet_terms",
              "bonus_status",
              "cashback_amount_dispute",
              "cashback_calculation_query",
              "claimed_missing_win",
              "compliment_no_action",
              "credible_self_harm",
              "deposit_limit_increase",
              "duplicate_card_charge",
              "explicit_permanent_self_exclusion",
              "failed_deposit_authorization_hold",
              "forgot_username_routine_recovery",
              "formal_withdrawal_complaint",
              "game_interruption_round_status",
              "game_result_dispute",
              "harm_linked_account_closure",
              "identity_document_upload_failure",
              "login_password_reset_failure",
              "loyalty_points_expiry",
              "marketing_opt_out",
              "missing_deposit",
              "missing_free_spins",
              "mobile_app_crash",
              "proof_of_address_requirements",
              "refund_request",
              "registered_mobile_change_request",
              "remove_active_cool_off",
              "repeated_withdrawal_complaint_escalation",
              "small_balance_discrepancy",
              "tax_information_request",
              "third_party_payment",
              "underage_gambling_report",
              "verification_pending",
              "vip_bonus_contact_unanswered",
              "wagering_requirement_information",
              "withdrawal_blocked",
              "withdrawal_delay",
              "withdrawal_repeated_unresolved",
              "withdrawal_status_first_contact",
              "withdrawal_timing_after_bonus",
              "unclassified_manual_review"
            ]
          },
          "score": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "match_mode": {
            "type": "string",
            "enum": [
              "any",
              "all"
            ]
          },
          "patterns": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "post_classification_refinements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "when",
          "set"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "when": {
            "type": "object"
          },
          "set": {
            "type": "object"
          },
          "add": {
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    },
    "behaviour_fixtures": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "message_id",
          "expected_top_intent"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "message_id": {
            "type": "string",
            "pattern": "^M\\d{2}$"
          },
          "expected_top_intent": {
            "type": "string",
            "enum": [
              "account_closure",
              "account_reopen_review",
              "account_transaction_statement_request",
              "account_takeover_report",
              "advertised_bonus_eligibility_dispute",
              "bonus_completed",
              "bonus_max_bet_terms",
              "bonus_status",
              "cashback_amount_dispute",
              "cashback_calculation_query",
              "claimed_missing_win",
              "compliment_no_action",
              "credible_self_harm",
              "deposit_limit_increase",
              "duplicate_card_charge",
              "explicit_permanent_self_exclusion",
              "failed_deposit_authorization_hold",
              "forgot_username_routine_recovery",
              "formal_withdrawal_complaint",
              "game_interruption_round_status",
              "game_result_dispute",
              "harm_linked_account_closure",
              "identity_document_upload_failure",
              "login_password_reset_failure",
              "loyalty_points_expiry",
              "marketing_opt_out",
              "missing_deposit",
              "missing_free_spins",
              "mobile_app_crash",
              "proof_of_address_requirements",
              "refund_request",
              "registered_mobile_change_request",
              "remove_active_cool_off",
              "repeated_withdrawal_complaint_escalation",
              "small_balance_discrepancy",
              "tax_information_request",
              "third_party_payment",
              "underage_gambling_report",
              "verification_pending",
              "vip_bonus_contact_unanswered",
              "wagering_requirement_information",
              "withdrawal_blocked",
              "withdrawal_delay",
              "withdrawal_repeated_unresolved",
              "withdrawal_status_first_contact",
              "withdrawal_timing_after_bonus",
              "unclassified_manual_review"
            ]
          }
        }
      }
    }
  }
}
